{
  "manifest_version": 3,
  "name": "Vicidial Monitor Pro",
  "version": "0.1.0",
  "description": "Pro Vicidial realtime monitor: auth + reliable background scraping + live streaming.",
  "action": {
    "default_title": "Vicidial Monitor Pro",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "http://localhost:3100/*",
    "https://axcl2s.dialerhosting.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["shared/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://axcl2s.dialerhosting.com/*realtime_report.php*"
      ],
      "js": ["content/content_script.js"],
      "run_at": "document_idle"
    }
  ]
}

