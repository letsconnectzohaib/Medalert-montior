        return el("tr", {}, [
          el("td", {}, [String(id)]),
          el("td", {}, [String(rep.shift_date || "—")]),
          el("td", {}, [String(rep.created_at || "—")]),
          el("td", {}, [reportFormatBadge(format || "—")]),
          el("td", {}, [
