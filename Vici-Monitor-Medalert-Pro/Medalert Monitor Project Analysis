  msg.textContent = "Loading…";

  const r = await fetchReportList(state.baseUrl, state.token, 50);
  if (!r.success) {
    msg.textContent = `Failed: ${r.error}`;
    host.textContent = "";
    return;
  }
  msg.textContent = `Loaded ${r.reports.length} reports.`;

  const table = el("table", {}, [
    el("thead", {}, [
      el("tr", {}, [
        el("th", {}, ["ID"]),
        el("th", {}, ["Shift date"]),
        el("th", {}, ["Created"]),
        el("th", {}, ["Format"]),
        el("th", {}, ["Actions"]),
      ]),
    ]),
    el(
      "tbody",
