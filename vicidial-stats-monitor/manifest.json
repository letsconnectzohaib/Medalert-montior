{
  "manifest_version": 3,
  "name": "Vicidial Stats Monitor Pro",
  "version": "1.0.0",
  "description": "Professional real-time dashboard for Vicidial statistics with enhanced monitoring capabilities.",
  "author": "Mr. Zohaib",
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "alarms"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "host_permissions": [
    "https://axcl2s.dialerhosting.com/*",
    "https://hooks.slack.com/*",
    "http://localhost:3000/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://axcl2s.dialerhosting.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vicidial Stats Monitor"
  }
}