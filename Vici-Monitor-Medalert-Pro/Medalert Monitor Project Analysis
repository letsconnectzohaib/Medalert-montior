export function normalizeBaseUrl(url) {
  const s = String(url || "").trim();
  return s ? s.replace(/\/$/, "") : "http://localhost:3100";
}

export async function pingGateway(baseUrl) {
  try {
    const res = await fetch(`${normalizeBaseUrl(baseUrl)}/api/health`);
    return res.ok;
  } catch {
    return false;
  }
}

